{
  "name": "@genie-react/cli",
  "version": "0.6.1",
  "description": "Give AI coding agents live React and TanStack DevTools from the terminal. Inspect, optimize, test, and verify a running app.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Genie-sa/genie-react.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/Genie-sa/genie-react#readme",
  "bugs": "https://github.com/Genie-sa/genie-react/issues",
  "keywords": [
    "react",
    "react-devtools",
    "react-performance",
    "tanstack-query",
    "tanstack-router",
    "ai-agent",
    "coding-agent",
    "claude-code",
    "codex",
    "vite",
    "nextjs",
    "debugging",
    "json",
    "cli"
  ],
  "author": "y0u-0",
  "type": "module",
  "bin": {
    "genie-react": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "genie-react": "workspace:*",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
