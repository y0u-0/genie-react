{
  "name": "@genie-react/cli",
  "version": "0.6.0",
  "description": "Genie CLI: wire the Vite plugin, then drive your app's live DevTools tools from a shell (status, tools, call).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Genie-sa/genie-react.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/Genie-sa/genie-react#readme",
  "bugs": "https://github.com/Genie-sa/genie-react/issues",
  "keywords": [
    "react",
    "tanstack",
    "devtools",
    "ai-agent",
    "claude",
    "vite",
    "cli"
  ],
  "author": "y0u-0",
  "type": "module",
  "bin": {
    "genie-react": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "genie-react": "workspace:*",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
