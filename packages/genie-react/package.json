{
  "name": "genie-react",
  "version": "0.3.0",
  "type": "module",
  "description": "Live DevTools for a running React + TanStack app, driven from the terminal by an AI agent — browser collectors, the <Genie /> component, the Vite plugin, and the WebSocket hub in one package.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/y0u-0/genie-react.git",
    "directory": "packages/genie-react"
  },
  "author": "y0u-0",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./hook": {
      "types": "./dist/hook.d.ts",
      "import": "./dist/hook.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./collectors": {
      "types": "./dist/collectors.d.ts",
      "import": "./dist/collectors.js"
    },
    "./script": {
      "types": "./dist/script.d.ts",
      "import": "./dist/script.js"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "import": "./dist/next.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js"
    },
    "./hub": {
      "types": "./dist/hub.d.ts",
      "import": "./dist/hub.js"
    },
    "./protocol": {
      "types": "./dist/protocol.d.ts",
      "import": "./dist/protocol.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@jridgewell/sourcemap-codec": "^1.5.5",
    "bippy": "^0.5.43",
    "superjson": "^2.2.6",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "@tanstack/react-query": ">=5",
    "@tanstack/react-router": ">=1",
    "react": ">=18",
    "vite": ">=5"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-query": {
      "optional": true
    },
    "@tanstack/react-router": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "^1.170.0",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/ws": "^8.18.1",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "vite": "^8.1.3"
  }
}
