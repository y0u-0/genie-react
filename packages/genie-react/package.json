{
  "name": "genie-react",
  "version": "0.6.1",
  "type": "module",
  "description": "Live React and TanStack DevTools for AI coding agents. Find performance problems, test app states, and verify fixes end to end.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Genie-sa/genie-react.git",
    "directory": "packages/genie-react"
  },
  "homepage": "https://github.com/Genie-sa/genie-react#readme",
  "bugs": "https://github.com/Genie-sa/genie-react/issues",
  "keywords": [
    "react",
    "react-devtools",
    "react-performance",
    "react-profiler",
    "tanstack-query",
    "tanstack-router",
    "vite",
    "nextjs",
    "react-native",
    "ai-agent",
    "developer-tools",
    "debugging"
  ],
  "author": "y0u-0",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./hook": {
      "types": "./dist/hook.d.ts",
      "import": "./dist/hook.js"
    },
    "./hook-hmr": {
      "types": "./dist/hook-hmr.d.ts",
      "import": "./dist/hook-hmr.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./collectors": {
      "types": "./dist/collectors.d.ts",
      "import": "./dist/collectors.js"
    },
    "./native": {
      "types": "./dist/native.d.ts",
      "import": "./dist/native.js",
      "default": "./dist/native.js"
    },
    "./script": {
      "types": "./dist/script.d.ts",
      "import": "./dist/script.js"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "import": "./dist/next.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js"
    },
    "./hub": {
      "types": "./dist/hub.d.ts",
      "import": "./dist/hub.js"
    },
    "./protocol": {
      "types": "./dist/protocol.d.ts",
      "import": "./dist/protocol.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@jridgewell/sourcemap-codec": "^1.5.5",
    "bippy": "^0.6.0",
    "superjson": "^2.2.6",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "@tanstack/react-query": ">=5",
    "@tanstack/react-router": ">=1",
    "react": ">=18",
    "vite": ">=5"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-query": {
      "optional": true
    },
    "@tanstack/react-router": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "^1.170.0",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/ws": "^8.18.1",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "vite": "^8.1.4"
  }
}
