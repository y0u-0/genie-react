{
  "name": "genie-react-agent",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Genie — give an AI coding agent full DevTools access to your live React + TanStack app from your terminal via the genie CLI.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Genie-sa/genie-react.git"
  },
  "author": "y0u-0",
  "packageManager": "pnpm@10.34.4",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/**\" build",
    "dev": "pnpm -r --parallel --filter \"./packages/**\" dev",
    "typecheck": "pnpm -r --filter \"./packages/**\" typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check . && node scripts/check-comments.mjs && node scripts/check-cli-ux.mjs",
    "check:docs": "pnpm --filter @genie-react/docs check",
    "test:e2e": "node scripts/check-vite-e2e.mjs",
    "check:e2e": "pnpm build && pnpm test:e2e",
    "test:compatibility": "node scripts/check-compatibility.mjs",
    "check:compatibility": "pnpm build && pnpm test:compatibility",
    "check:release": "node scripts/prepare-release.mjs",
    "check": "pnpm lint && pnpm typecheck && pnpm build && pnpm check:release && pnpm test && pnpm check:docs",
    "format": "biome format --write .",
    "fix": "biome check --write .",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.5",
    "@changesets/cli": "^2.31.1",
    "@types/node": "^26.1.1",
    "pkg-pr-new": "^0.0.79",
    "playwright": "^1.61.1",
    "tsdown": "^0.22.14",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
