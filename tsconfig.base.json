{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "genie-react": ["./packages/genie-react/src/react/index.ts"],
      "genie-react/hook": ["./packages/genie-react/src/collectors/react/hook.ts"],
      "genie-react/client": ["./packages/genie-react/src/client-entry.ts"],
      "genie-react/vite": ["./packages/genie-react/src/vite/index.ts"],
      "genie-react/hub": ["./packages/genie-react/src/hub/index.ts"],
      "genie-react/protocol": ["./packages/genie-react/src/protocol/index.ts"],
      "@genie-react/cli": ["./packages/cli/src/index.ts"]
    },
    "moduleDetection": "force",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "skipLibCheck": true,
    "noEmit": true
  }
}
